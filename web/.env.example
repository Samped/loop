# SoSoValue — get a free key at https://openapi.sosovalue.com
SOSOVALUE_API_KEY=

# USDC-reserved StockVault on Arc
NEXT_PUBLIC_STOCK_VAULT_ADDRESS=
STOCK_VAULT_ADDRESS=

# For deploying contracts, syncing oracle prices, and on-chain txs (never commit)
PRIVATE_KEY=

# Auto-push SoSoValue prices to vault oracle (milliseconds, default 60000)
ORACLE_SYNC_INTERVAL_MS=60000

# Background SoSoValue news ingestion (milliseconds, default 600000)
NEWS_SYNC_INTERVAL_MS=600000
