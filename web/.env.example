# SoSoValue — get a free key at https://openapi.sosovalue.com
SOSOVALUE_API_KEY=

# Supplemental news sources (optional — Google News + CoinDesk RSS used when keys are absent)
# Finnhub — https://finnhub.io
FINNHUB_API_KEY=
# CryptoPanic — https://cryptopanic.com/developers/api/
CRYPTOPANIC_API_KEY=

# USDC-reserved StockVault on Arc (spot — separate from perps)
NEXT_PUBLIC_STOCK_VAULT_ADDRESS=
STOCK_VAULT_ADDRESS=

# PerpEngine — independent perpetual futures (deploy via contracts/script/DeployPerp.s.sol)
NEXT_PUBLIC_PERP_ENGINE_ADDRESS=
PERP_ENGINE_ADDRESS=

# Perp mark engine — index-only (default) or demo stochastic (gbm)
# live = real stock index (Finnhub + SoSoValue median), no synthetic noise
# gbm  = demo microstructure simulator (testnet only)
PERP_MARK_MODE=live
PERP_INDEX_POLL_MS=400
PERP_INDEX_CACHE_MS=2000
PERP_INDEX_TWAP_TICKS=8
PERP_BASIS_VOL=0.95
PERP_MAX_BASIS=0.035
PERP_BASIS_JUMP_PROB=0.01
PERP_VOB_MAX_SPREAD_BPS=28
PERP_VOB_IMPACT_STRENGTH=1.4
# PERP_IGNORE_MARKET_HOURS=1

# Demo-only (PERP_MARK_MODE=gbm):
# PERP_MARK_TICK_MS=1000
# PERP_MARK_VOL_MULTIPLIER=8
# PERP_MARK_MEAN_REVERSION=2
# PERP_MARK_JUMP_PROB=0.004
# PERP_MARK_MAX_DEVIATION=0.2

PERP_ORACLE_SYNC_INTERVAL_MS=5000

# For deploying contracts, syncing oracle prices, and on-chain txs (never commit)
PRIVATE_KEY=

# Protects admin POST routes (perp/oracle sync, liquidation, news sync). Send as x-admin-key header.
ADMIN_API_KEY=

# Auto-push SoSoValue prices to vault oracle (milliseconds, default 60000)
ORACLE_SYNC_INTERVAL_MS=60000

# Background SoSoValue news ingestion (milliseconds, default 600000)
NEWS_SYNC_INTERVAL_MS=600000

# Public docs site (GitBook or custom domain, e.g. https://loop.gitbook.io/loop)
NEXT_PUBLIC_DOCS_URL=

# Neon Postgres (recommended for Vercel)
# Use pooled connection string from Neon dashboard.
# Set NEON_ENABLED=0 when Neon is unreachable locally (app uses local JSON for perp history).
NEON_ENABLED=1
NEON_DATABASE_URL=



