{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "regions": ["iad1"],
  "functions": {
    "src/app/api/market/bootstrap/route.ts": {
      "maxDuration": 25
    },
    "src/app/api/market/snapshots/route.ts": {
      "maxDuration": 25
    },
    "src/app/api/portfolio/[address]/route.ts": {
      "maxDuration": 30
    },
    "src/app/api/perp/positions/[address]/route.ts": {
      "maxDuration": 15
    },
    "src/app/api/news/route.ts": {
      "maxDuration": 25
    }
  }
}
